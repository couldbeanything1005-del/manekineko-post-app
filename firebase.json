{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "functions/**",
      "netlify/**",
      "netlify.toml",
      "node_modules/**",
      ".git/**"
    ],
    "rewrites": [
      {
        "source": "/api/generate",
        "function": {
          "functionId": "generate",
          "region": "us-central1"
        }
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
